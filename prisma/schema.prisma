datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           Int             @id @default(autoincrement())
  email        String          @unique
  passwordHash String          @map("password_hash")
  createdAt    DateTime        @default(now()) @map("created_at")
  repas        Repas[]
  programmation Programmation[]
  shoppingList  ShoppingListItem[]
  shoppingListExtras ShoppingListExtra[]

  @@map("users")
}

model Repas {
  id            Int               @id @default(autoincrement())
  userId        Int               @map("user_id")
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  titre         String
  recette       String?
  photoUrl      String?           @map("photo_url")
  createdAt     DateTime          @default(now()) @map("created_at")
  ingredients   RepasIngredient[]
  programmation Programmation[]
  shoppingListExtras ShoppingListExtra[]

  @@map("repas")
  @@index([userId])
}

model Ingredient {
  id           Int                @id @default(autoincrement())
  nom          String             @unique
  categorie    String             // e.g., "fruits-legumes", "epicerie-salee"
  repas        RepasIngredient[]
  shoppingList ShoppingListItem[]
  shoppingListExtras ShoppingListExtra[]

  @@map("ingredients")
}

model RepasIngredient {
  id           Int        @id @default(autoincrement())
  repasId      Int        @map("repas_id")
  repas        Repas      @relation(fields: [repasId], references: [id], onDelete: Cascade)
  ingredientId Int        @map("ingredient_id")
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  quantite     Float?
  unite        String?

  @@map("repas_ingredients")
  @@index([repasId])
  @@index([ingredientId])
}

model Programmation {
  id      Int      @id @default(autoincrement())
  userId  Int      @map("user_id")
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  repasId Int      @map("repas_id")
  repas   Repas    @relation(fields: [repasId], references: [id], onDelete: Cascade)
  date    DateTime
  heure   Int      // 0 = midi, 1 = soir

  @@map("programmation")
  @@index([userId])
  @@index([repasId])
}

model ShoppingListItem {
  id           Int        @id @default(autoincrement())
  userId       Int        @map("user_id")
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  ingredientId Int        @map("ingredient_id")
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  quantite     Float?
  unite        String?
  isChecked    Boolean    @default(false) @map("is_checked")
  week         Int
  year         Int
  createdAt    DateTime   @default(now()) @map("created_at")

  @@unique([userId, week, year, ingredientId, unite])
  @@map("shopping_list_items")
}

model ShoppingListExtra {
  id           Int        @id @default(autoincrement())
  userId       Int        @map("user_id")
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  ingredientId Int?       @map("ingredient_id")
  ingredient   Ingredient? @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  quantite     Float?
  unite        String?
  repasId      Int?       @map("repas_id")
  repas        Repas?     @relation(fields: [repasId], references: [id], onDelete: Cascade)
  week         Int
  year         Int
  createdAt    DateTime   @default(now()) @map("created_at")

  @@map("shopping_list_extras")
  @@index([userId])
  @@index([repasId])
  @@index([ingredientId])
}
